# GitHub OAuth App credentials — get from github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:5001/auth/callback

# Google Gemini API key — get from aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Port for the Express server (default: 5001)
PORT=5001

# The URL of your deployed frontend (e.g. https://your-vercel-url.vercel.app)
FRONTEND_URL=http://localhost:5173
